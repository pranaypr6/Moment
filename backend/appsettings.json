{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=moment_db;Username=${DB_USER};Password=${DB_PASSWORD}"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "moment-api",
    "Audience": "moment-app"
  },
  "MomentLimits": {
    "HourlyLimit": 5,
    "DailyLimit": 20
  },
  "RevenueCat": {
    "WebhookSecret": "rc_webhook_sec_example_12345"
  }
}
